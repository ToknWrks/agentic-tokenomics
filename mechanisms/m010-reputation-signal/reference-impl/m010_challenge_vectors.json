    {
      "id": "challenge_flow_04",
      "title": "Timeout escalation: challenge unresolved past deadline triggers escalation",
      "subject": {
        "subject_type": "Methodology",
        "subject_id": "METH-SoilCarbon-v3",
        "category": "method_rigor"
      },
      "timeline": [
        {
          "step": 1,
          "action": "submit_and_activate",
          "timestamp": "2026-03-01T00:00:00Z",
          "activation_time": "2026-03-02T01:00:00Z",
          "event": {
            "signaler_id": "signaler_E",
            "endorsement_level": 4,
            "stake": 250
          },
          "expected_state": "ACTIVE",
          "expected_score": {
            "reputation_score_0_1": 0.8,
            "reason": "Active signal, endorsement_level=4"
          }
        },
        {
          "step": 2,
          "action": "challenge",
          "timestamp": "2026-03-05T00:00:00Z",
          "event": {
            "challenger_id": "challenger_W",
            "stake": 250,
            "rationale": "Methodology has known flaws in carbon sequestration measurement.",
