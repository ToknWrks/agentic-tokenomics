  "vectors": [
    {
      "id": "challenge_flow_01",
      "title": "Single signal: active → challenged → resolved VALID → score restores",
      "subject": {
        "subject_type": "Project",
        "subject_id": "P-regen-042",
        "category": "delivery_risk"
      },
      "timeline": [
        {
          "step": 1,
          "action": "submit_signal",
          "timestamp": "2026-03-01T00:00:00Z",
          "event": {
            "signaler_id": "signaler_A",
            "endorsement_level": 4,
            "stake": 200,
            "evidence": {
              "koi_links": ["koi://note/project-042-review"],
              "ledger_refs": ["ledger://tx/2001"]
            }
          },
          "expected_state": "SUBMITTED",
          "expected_score": {
            "reputation_score_0_1": 0.0,
            "reason": "Signal in SUBMITTED state; activation delay not yet passed"
          }
        },
        {
          "step": 2,
          "action": "activate",
          "timestamp": "2026-03-02T01:00:00Z",
          "event": {},
          "expected_state": "ACTIVE",
          "expected_score": {
            "reputation_score_0_1": 0.8,
            "reason": "Single signal with endorsement_level=4 → 4/5 = 0.8 (minimal decay at 25h)"
          }
        },
        {
          "step": 3,
          "action": "challenge",
          "timestamp": "2026-03-05T00:00:00Z",
          "event": {
            "challenger_id": "challenger_X",
            "stake": 200,
            "rationale": "Endorsement appears based on outdated project data from 2024.",
            "evidence": {
              "koi_links": ["koi://note/challenge-evidence-042"],
              "ledger_refs": []
            }
          },
          "expected_state": "CHALLENGED",
          "expected_score": {
            "reputation_score_0_1": 0.0,
            "reason": "Challenged signal paused; contribution drops to 0"
          }
        },
        {
          "step": 4,
          "action": "resolve_valid",
          "timestamp": "2026-03-10T00:00:00Z",
          "event": {
            "resolver": "admin",
            "rationale": "Project data verified as current; endorsement is valid."
          },
          "expected_state": "RESOLVED_VALID",
          "expected_score": {
            "reputation_score_0_1": 0.8,
            "reason": "Signal restored after VALID resolution; score contribution resumes (decay minor over 9 days)"
          }
        }
      ]
    },
