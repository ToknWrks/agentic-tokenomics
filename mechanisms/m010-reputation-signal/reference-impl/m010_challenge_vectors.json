              "koi_links": ["koi://note/methodology-flaw-report"],
              "ledger_refs": ["ledger://tx/5001"]
            }
          },
          "expected_state": "CHALLENGED",
          "expected_score": {
            "reputation_score_0_1": 0.0,
            "reason": "Signal paused during challenge"
          }
        },
        {
          "step": 3,
          "action": "check_timeout_day_10",
          "timestamp": "2026-03-15T00:00:00Z",
          "event": {},
          "expected_state": "CHALLENGED",
          "expected_escalated": false,
          "expected_score": {
            "reputation_score_0_1": 0.0,
            "reason": "Still within 14-day resolution deadline; no escalation"
          }
        },
        {
          "step": 4,
          "action": "check_timeout_day_15",
          "timestamp": "2026-03-20T00:00:00Z",
          "event": {},
          "expected_state": "ESCALATED",
          "expected_escalated": true,
          "expected_score": {
            "reputation_score_0_1": 0.0,
            "reason": "Resolution deadline exceeded; auto-escalated to governance. Score still paused."
          }
        },
        {
          "step": 5,
          "action": "governance_resolve_valid",
          "timestamp": "2026-03-25T00:00:00Z",
          "event": {
            "resolver": "governance",
            "rationale": "Governance vote: methodology flaws are non-material. Signal valid."
